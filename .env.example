# AI Model API Keys
OPENAI_API_KEY=your_chatgpt_api_key_here
HUGGINGFACE_TOKEN=your_huggingface_token_here

# Environment
ENVIRONMENT=development

# Cache Settings
CACHE_TTL_DAYS=7
CACHE_DB_PATH=data/question_cache.db

# Model Settings
PRIMARY_MODEL=chatgpt
FALLBACK_MODEL=huggingface
MAX_RETRIES=2

# Server
PORT=8000
HOST=0.0.0.0
